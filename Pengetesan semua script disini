-- Helper: Find Orion ScreenGui dynamically across RobloxGui, CoreGui, and PlayerGui
local function getOrionGui()
    local rg = game:GetService("CoreGui"):FindFirstChild("RobloxGui")
    if rg and rg:FindFirstChild("Orion") then
        return rg.Orion
    end
    local o = game:GetService("CoreGui"):FindFirstChild("Orion")
    if o then return o end
    
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        if pg:FindFirstChild("Orion") then return pg.Orion end
    end
    return nil
end

-- Toggle Exploit GUI visibility Keybind listener
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == UIKey then
        local OrionGui = getOrionGui()
        if OrionGui then
            OrionGui.Enabled = not OrionGui.Enabled
        end
    end
end)
