-- Helper: Get local character's damaging part
local function getDamagingPart()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local tool = myChar:FindFirstChildOfClass("Tool")
    if tool then
        return tool:FindFirstChild("Handle") or tool:FindFirstChildOfClass("BasePart")
    end
    return myChar:FindFirstChild("Right Hand") or myChar:FindFirstChild("Right Arm") or
           myChar:FindFirstChild("Left Hand") or myChar:FindFirstChild("Left Arm") or
           myChar:FindFirstChild("HumanoidRootPart")
end

-- Helper: Check if local player is typing in chat
local function isTyping()
    local UserInputService = game:GetService("UserInputService")
    return UserInputService:GetFocusedTextBox() ~= nil
end

-- Visualizer Setup
local visualizer = Instance.new("Part")
visualizer.Material = Enum.Material.ForceField
visualizer.CanCollide = false
visualizer.Anchored = true
visualizer.CastShadow = false
visualizer.Transparency = VisualizerTransparency
visualizer.Color = VisualizerColor
visualizer.BottomSurface = Enum.SurfaceType.Smooth
visualizer.TopSurface = Enum.SurfaceType.Smooth

local RunService = game:GetService("RunService")
RunService.RenderStepped:Connect(function()
    if ReachEnabled and VisualizerEnabled then
        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local dp = getDamagingPart()
        
        if myHRP and dp then
            visualizer.Parent = workspace
            visualizer.Color = VisualizerColor
            visualizer.Transparency = VisualizerTransparency
            
            if ReachType == "Sphere" then
                visualizer.Shape = Enum.PartType.Ball
                visualizer.Size = Vector3.new(ReachDistance, ReachDistance, ReachDistance)
                visualizer.CFrame = dp.CFrame
            else -- Line Reach (Corrected to project from HumanoidRootPart directly in front)
                visualizer.Shape = Enum.PartType.Block
                visualizer.Size = Vector3.new(6, 6, ReachDistance)
                visualizer.CFrame = myHRP.CFrame * CFrame.new(0, 0, -(ReachDistance / 2) - 2)
            end
        else
            visualizer.Parent = nil
        end
    else
        visualizer.Parent = nil
    end
end)

-- Main Combat/Reach Loop (RenderStepped)
RunService.RenderStepped:Connect(function()
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    local dp = getDamagingPart()
    
    if ReachEnabled and dp then
        pcall(function()
            for _, targetPlayer in ipairs(Players:GetPlayers()) do
                if targetPlayer ~= LocalPlayer and targetPlayer.Character then
                    local tChar = targetPlayer.Character
                    local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                    local tHum = tChar:FindFirstChildOfClass("Humanoid")
                    
                    if tHRP and tHum and tHum.Health > 0 then
                        local relativePos = myHRP.CFrame:PointToObjectSpace(tHRP.Position)
                        local inRange = false
                        
                        if ReachType == "Sphere" then
                            inRange = (tHRP.Position - myHRP.Position).Magnitude <= ReachDistance
                        else
                            inRange = (relativePos.Z < 0) and (-relativePos.Z <= ReachDistance) and (math.abs(relativePos.X) <= 6) and (math.abs(relativePos.Y) <= 6)
                        end
                        
                        if inRange then
                            -- 1. CBring (locally teleports parts and caches offsets for resync)
                            if UseCBring then
                                local partsToBring = {
                                    tChar:FindFirstChild("Left Arm"),
                                    tChar:FindFirstChild("Left Leg")
                                }
                                for _, part in ipairs(partsToBring) do
                                    if part then
                                        if not cbringActiveParts[part] then
                                            cbringActiveParts[part] = {
                                                Offset = tHRP.CFrame:ToObjectSpace(part.CFrame),
                                                CanCollide = part.CanCollide,
                                                HRP = tHRP
                                            }
                                        end
                                        part.CanCollide = false
                                        pcall(function()
                                            part:BreakJoints()
                                        end)
                                        part.CFrame = myHRP.CFrame * CFrame.new(1, 0, -3.5)
                                    end
                                end
                            end
                            
                            -- 2. FTI (Fast TouchInterest simulation)
                            if UseFTI then
                                local targetLimb = tChar:FindFirstChild("Left Arm") or tChar:FindFirstChild("Left Leg")
                                if targetLimb then
                                    firetouchinterest(targetLimb, dp, 0)
                                    firetouchinterest(targetLimb, dp, 1)
                                end
                            end
                        end
                    end
                end
            end
        end)
    end

    -- Clean up and resync positions for parts that are out of reach or if CBring is disabled
    for part, data in pairs(cbringActiveParts) do
        local shouldRestore = false
        if not ReachEnabled or not UseCBring then
            shouldRestore = true
        else
            local hrp = data.HRP
            if hrp and hrp.Parent then
                local relativePos = myHRP.CFrame:PointToObjectSpace(hrp.Position)
                local inRange = false
                if ReachType == "Sphere" then
                    inRange = (hrp.Position - myHRP.Position).Magnitude <= ReachDistance
                else
                    inRange = (relativePos.Z < 0) and (-relativePos.Z <= ReachDistance) and (math.abs(relativePos.X) <= 6) and (math.abs(relativePos.Y) <= 6)
                end
                if not inRange then
                    shouldRestore = true
                end
            else
                shouldRestore = true
            end
        end

        if shouldRestore then
            pcall(function()
                if part and part.Parent and data.HRP and data.HRP.Parent then
                    part.CFrame = data.HRP.CFrame * data.Offset
                    part.CanCollide = data.CanCollide
                end
            end)
            cbringActiveParts[part] = nil
        end
    end
end)

-- Aimbot Target Acquisition
local function getAimbotTarget()
    if currentAimbotTarget and currentAimbotTarget.Parent then
        local hum = currentAimbotTarget.Parent:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            return currentAimbotTarget
        end
    end

    local target = nil
    local minVal = math.huge
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    local Camera = workspace.CurrentCamera
    pcall(function()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local tChar = player.Character
                local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                local tHum = tChar:FindFirstChildOfClass("Humanoid")
                if tHRP and tHum and tHum.Health > 0 then
                    local targetPart = tChar:FindFirstChild(AimbotPart) or tHRP
                    if AimbotTargetMode == "Distance" then
                        local dist = (tHRP.Position - myHRP.Position).Magnitude
                        if dist < minVal then
                            minVal = dist
                            target = targetPart
                        end
                    elseif AimbotTargetMode == "Mouse" then
                        local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                        if onScreen then
                            local mousePos = game:GetService("UserInputService"):GetMouseLocation()
                            local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                            if dist < minVal and dist <= AimbotFOV then
                                minVal = dist
                                target = targetPart
                            end
                        end
                    end
                end
            end
        end
    end)
    
    currentAimbotTarget = target
    return target
end

-- Aimbot Camera Binder (Enum.RenderPriority.Camera.Value + 1 overrides default camera scripts and prevents desync/jitter)
RunService:BindToRenderStep("AntigravityAimbot", Enum.RenderPriority.Camera.Value + 1, function()
    if AimbotEnabled and AimbotActive then
        local target = getAimbotTarget()
        if target then
            local Camera = workspace.CurrentCamera
            local targetLook = CFrame.new(Camera.CFrame.Position, target.Position)
            Camera.CFrame = Camera.CFrame:Lerp(targetLook, AimbotSmoothness)
        end
    end
end)

-- Input check handler for Keyboard & Mouse buttons
local function checkAimbotInput(input)
    if AimbotMouse then
        return input.UserInputType == AimbotMouse
    else
        return input.KeyCode == AimbotKey
    end
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if checkAimbotInput(input) then
        if AimbotMode == "Hold" then
            AimbotActive = true
        else
            AimbotActive = not AimbotActive
            if not AimbotActive then
                currentAimbotTarget = nil
            end
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gpe)
    if gpe then return end
    if checkAimbotInput(input) then
        if AimbotMode == "Hold" then
            AimbotActive = false
            currentAimbotTarget = nil
        end
    end
end)

-- Auto Clicker Loop Thread (Checks if local user is currently typing to prevent chat interference)
task.spawn(function()
    while true do
        task.wait(AutoClickerDelay)
        if AutoClickerEnabled and not isTyping() then
            pcall(function()
                local myChar = LocalPlayer.Character
                local myTool = myChar and myChar:FindFirstChildOfClass("Tool")
                if myTool then
                    myTool:Activate()
                end
                local vu = game:GetService("VirtualUser")
                vu:CaptureController()
                vu:ClickButton1(Vector2.new(0, 0))
            end)
        end
    end
end)

