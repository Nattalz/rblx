local function clearCustomAC()
    local Tracker = PlayerGui:FindFirstChild("Tracker")
    local Loop = PlayerGui:FindFirstChild("Loop")
    if Tracker then Tracker:Destroy() end
    if Loop then Loop:Destroy() end

    local anti = PlayerGui:FindFirstChild("anti")
    if anti then anti:Destroy() end
    
    local starterAnti = StarterGui:FindFirstChild("anti")
    if starterAnti then starterAnti:Destroy() end
end

clearCustomAC()

PlayerGui.ChildAdded:Connect(function(child)
    if child.Name == "Tracker" or child.Name == "Loop" or child.Name == "anti" then
        task.spawn(function()
            local t = PlayerGui:FindFirstChild("Tracker")
            local l = PlayerGui:FindFirstChild("Loop")
            local a = PlayerGui:FindFirstChild("anti")
            if t then t:Destroy() end
            if l then l:Destroy() end
            if a then a:Destroy() end
        end)
    end
end)

local function handleToolAC(tool)
    if tool:IsA("Tool") then
        if tool.Name == "WWE Clean" then
            local acScript = tool:WaitForChild("LocalScript", 2)
            if acScript then acScript:Destroy() end
        end
    end
end

LocalPlayer.Character.ChildAdded:Connect(handleToolAC)
LocalPlayer.Backpack.ChildAdded:Connect(handleToolAC)

for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
    handleToolAC(tool)
end
if LocalPlayer.Character then
    for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
        handleToolAC(tool)
    end
end

